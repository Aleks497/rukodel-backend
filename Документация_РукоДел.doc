    h1{font-size:20pt; margin:0 0 10px 0;}
    h2{font-size:16pt; margin:18px 0 8px;}
    h3{font-size:13pt; margin:14px 0 6px;}
    .muted{color:#555;}
    .meta{margin:0 0 14px 0;}
    .box{border:1px solid #ddd; padding:10px 12px; border-radius:6px; margin:10px 0;}
    table{border-collapse:collapse; width:100%; margin:8px 0 12px;}
    th,td{border:1px solid #ddd; padding:8px; vertical-align:top;}
    th{background:#f5f5f5; text-align:left;}
    code, pre{font-family:Consolas, "Courier New", monospace; font-size:10.5pt;}
